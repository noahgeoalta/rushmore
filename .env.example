# RUSHMORE — environment variables (copy to .env.local, never commit real values)

# --- Microsoft Graph ---
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:3000/api/auth/callback
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# --- GitHub ---
GITHUB_TOKEN=

# --- AI ---
ANTHROPIC_API_KEY=

# --- ElevenLabs TTS (optional — falls back to browser TTS if not set) ---
# Get API key: https://elevenlabs.io
# Voice ID: find it on the voice page URL or via /v1/voices API
# For Richter (Black Ops 4 Alpha Omega vibe), use a cloned or similar deep gravelly voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Upstash Redis (notes sync) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- App login ---
RUSHMORE_PASSWORD=
