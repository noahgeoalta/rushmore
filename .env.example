# RUSHMORE — environment variables (copy to .env.local, never commit real values)
# All empty in M0. Filled in at M1 (Microsoft auth) and M4 (GitHub boards).

# --- Microsoft Graph (M1) ---
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- GitHub (M4) ---
GITHUB_TOKEN_WORK=
GITHUB_TOKEN_PERSONAL=

# --- App login (M7) ---
RUSHMORE_PASSWORD=
